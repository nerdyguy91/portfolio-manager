# Database
# SQLite (local dev default — leave unset to use sqlite:///db/portfolio.db)
# PostgreSQL (production — use Neon or similar)
DATABASE_URL=postgresql://user:pass@host/portfolio?sslmode=require

# API Keys
FRED_API_KEY=your_fred_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_16char_app_password
ALERT_EMAIL_TO=you@gmail.com

# CORS — comma-separated list of allowed frontend origins
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000
